# ============================================================
# LIFE SYSTEM 2026 — Variables de entorno
# Para desarrollo local: copia esto como .dev.vars (NO .env)
# En producción: configurar en Cloudflare Pages dashboard
# ============================================================

# URL de tu proyecto Supabase
# Cloudflare Dashboard → Settings → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key (NUNCA en el frontend, solo en el backend/Functions)
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
